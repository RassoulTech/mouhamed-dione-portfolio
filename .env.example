# Configuration Firebase — copie ce fichier en ".env" et remplis les valeurs.
# Tu les trouves dans : Firebase Console > Paramètres du projet > Tes applications.
# (Voir FIREBASE-SETUP.md pour le guide pas à pas.)
#
# NB : ces clés ne sont pas secrètes (elles vivent côté navigateur).
# La sécurité vient de l'authentification + des règles Firestore.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Email autorisé à administrer le blog (page /admin). Mets ton adresse.
VITE_ADMIN_EMAIL=
