rules_version = '2';

// Règles de sécurité Firestore pour le blog.
// - Tout le monde peut LIRE les articles publiés.
// - Seul un utilisateur CONNECTÉ (toi) peut créer / modifier / supprimer.
//
// À coller dans : Firebase Console > Firestore Database > Règles > Publier.

service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{slug} {
      allow read: if resource.data.published == true || request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
  }
}
