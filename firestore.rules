rules_version = '2';

// Règles de sécurité Firestore pour le blog.
// - Tout le monde peut LIRE les articles publiés.
// - Seul TON compte (ton email) peut créer / modifier / supprimer,
//   même si la connexion Google est activée pour d'autres.
//
// ⚠️ Remplace l'email ci-dessous par le tien si besoin.
// À coller dans : Firebase Console > Firestore Database > Règles > Publier.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "dionemhd1@gmail.com";
    }

    match /posts/{slug} {
      allow read: if resource.data.published == true || isOwner();
      allow create, update, delete: if isOwner();
    }
  }
}
